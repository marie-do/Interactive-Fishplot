)
)
})
observeEvent(input$confirm_delete_meta, {
req(input$meta_field_to_delete)
rv$metadata_df[[input$meta_field_to_delete]] <- NULL
removeModal()
showNotification("Metadata field deleted",
type = "warning")
})
observeEvent(input$add_drug, {
showModal(
modalDialog(
title = "Add new drug",
textInput("new_drug_name", "Drug name"),
footer = tagList(
modalButton("Cancel"),
actionButton("confirm_add_drug", "Add")
)
)
)
})
observeEvent(input$confirm_add_drug, {
req(input$new_drug_name)
rv$available_drugs <- unique(
c(rv$available_drugs, input$new_drug_name)
)
removeModal()
})
# Reactive matrix AFTER drug + constraints
final_matrix_reactive <- reactive({
req(input$patient, rv$objects)
patient <- input$patient
mat <- rv$objects$concat_by_patient_hierarchy[[patient]]
if (is.null(mat)) return(NULL)
parents <- rv$objects$all_patient_hierarchies[[patient]]$parent_index
mat_final <- mat
# monotime fix
if (ncol(mat_final) == 1) {
mat_final <- cbind(mat_final, mat_final)
colnames(mat_final) <- c("t1","t1'")
}
# apply drug effect
if (ncol(mat_final) >= 3) {
for (col in seq(2, ncol(mat_final) - 1, by = 2)) {
key <- paste(
patient,
input$selected_drug,
col,
sep = "_"
)
effect <- rv$drug_effects[[key]]
if (is.null(effect)) {
effect <- generate_random_drug_effects()
rv$drug_effects[[key]] <- effect
}
if (length(effect) == 1){
mat_final[,col] <- mat_final[, col -1] * effect
} else {
mat_final[,col]<- mat_final[,col -1] * effect [rownames(mat_final)]
}
}
}
mat_final <- fix_zero_reappearance(mat_final)
mat_final <- enforce_fishplot_constraints(mat_final, parents)
mat_final[!is.finite(mat_final)] <- 0
mat_final[mat_final < 0] <- 0
mat_final
})
output$matrix_table <- renderDT({
mat <- final_matrix_reactive()
if (is.null(mat)) return(NULL)
clone_ids <- rownames(mat)
mutation_labels <- sapply(
clone_ids,
get_clone_label,
patient_id = input$patient,
mutation_lookup = rv$objects$mutation_lookup
)
df <- as.data.frame(mat)
df$Clone <- clone_ids
df$Mutation <- mutation_labels
df <- df %>%
select(Clone, Mutation, everything())
# round only numeric columns
df_numeric_cols <- sapply(df, is.numeric)
df[df_numeric_cols] <- round(df[df_numeric_cols], 3)
datatable(
df,
rownames = FALSE,
options = list(
scrollX = TRUE,
pageLength = nrow(df)
)
)
})
}
shinyApp(ui, server)
q()
