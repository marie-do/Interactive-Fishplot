# Créer une version simplifiée des fonctions fishplot
create_fishplot <- function(fishes, shape="spline", title="Fishplot") {
library(ggplot2)
# Code simplifié pour créer un graphique de type fishplot
# Cette version basique peut être étendue selon vos besoins
ggplot(fishes) +
geom_area(aes(x=timepoint, y=fraction, fill=clone),
position="stack", alpha=0.8) +
scale_fill_brewer(type="qual", palette="Set3") +
labs(title=title, x="Time", y="Fraction") +
theme_minimal()
}
# Fonction pour préparer les données
prepare_fish_data <- function(timepoints, fractions) {
# Fonction utilitaire pour formater les données
# À adapter selon vos données spécifiques
}
library(ggplot2)
library(RColorBrewer)
# Fonction pour créer un objet fish
createFishObject <- function(frac.table, parents, timepoints = NULL) {
if (is.null(timepoints)) {
timepoints <- 1:ncol(frac.table)
}
fish <- list(
frac.table = frac.table,
parents = parents,
timepoints = timepoints,
num.clones = nrow(frac.table),
num.timepoints = ncol(frac.table)
)
return(fish)
}
# Fonction pour calculer le layout des clones
layoutClones <- function(fish) {
# Calculer les positions cumulatives pour chaque clone
fish$cumulative <- matrix(0, nrow = fish$num.clones, ncol = fish$num.timepoints)
# Pour chaque timepoint, calculer les positions cumulatives
for (t in 1:fish$num.timepoints) {
cumsum_val <- 0
for (clone in 1:fish$num.clones) {
fish$cumulative[clone, t] <- cumsum_val
cumsum_val <- cumsum_val + fish$frac.table[clone, t]
}
}
return(fish)
}
# Fonction principale pour dessiner le fishplot
fishPlot <- function(fish, shape = "spline", title.btm = "", cex.title = 1,
vlines = NULL, vlab = NULL, col = NULL) {
# Préparer les données pour ggplot
plot_data <- data.frame()
for (clone in 1:fish$num.clones) {
for (t in 1:fish$num.timepoints) {
if (fish$frac.table[clone, t] > 0) {
# Position du bas et du haut pour chaque clone
y_bottom <- fish$cumulative[clone, t]
y_top <- y_bottom + fish$frac.table[clone, t]
plot_data <- rbind(plot_data, data.frame(
timepoint = fish$timepoints[t],
clone = as.factor(clone),
y_bottom = y_bottom,
y_top = y_top,
fraction = fish$frac.table[clone, t]
))
}
}
}
# Créer les couleurs si non spécifiées
if (is.null(col)) {
if (fish$num.clones <= 8) {
colors <- brewer.pal(max(3, fish$num.clones), "Set2")
} else {
colors <- rainbow(fish$num.clones)
}
} else {
colors <- col
}
# Créer le graphique de base
p <- ggplot(plot_data) +
geom_ribbon(aes(x = timepoint, ymin = y_bottom, ymax = y_top,
fill = clone, group = clone),
alpha = 0.8) +
scale_fill_manual(values = colors[1:fish$num.clones]) +
labs(title = title.btm, x = "Time", y = "Percentage", fill = "Clone") +
theme_minimal() +
theme(plot.title = element_text(size = 12 * cex.title, hjust = 0.5)) +
ylim(0, 100)
# Ajouter les lignes verticales si spécifiées
if (!is.null(vlines)) {
p <- p + geom_vline(xintercept = vlines, linetype = "dashed", color = "gray50")
# Ajouter les labels si spécifiés
if (!is.null(vlab) && length(vlab) == length(vlines)) {
for (i in 1:length(vlines)) {
p <- p + annotate("text", x = vlines[i], y = 105,
label = vlab[i], angle = 90, hjust = 0, size = 3)
}
}
}
# Afficher le graphique
print(p)
return(p)
}
